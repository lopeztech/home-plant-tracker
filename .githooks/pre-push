#!/usr/bin/env bash
# Runs npm run preflight:fast before every push.
# Skip with: git push --no-verify (or set SKIP_PREFLIGHT=1)

set -e

if [ "${SKIP_PREFLIGHT:-0}" = "1" ]; then
  echo "pre-push: SKIP_PREFLIGHT=1 set, skipping preflight"
  exit 0
fi

echo "pre-push: running 'npm run preflight:fast' (set SKIP_PREFLIGHT=1 to bypass)"
npm run preflight:fast
